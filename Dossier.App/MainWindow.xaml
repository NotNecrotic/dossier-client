<Window
    x:Class="Dossier.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Dossier.App"
    xmlns:client="using:Dossier.Client.Core.State"
    Title="Dossier Client">

    <Grid ColumnDefinitions="250,*,300">

        <!-- LEFT: CONFIG -->
        <StackPanel Grid.Column="0" Padding="10" Spacing="10">

            <TextBlock Text="Settings" FontSize="18"/>

            <TextBox Header="Server URL" />
            <TextBox Header="API Key" />

            <Button Content="Add Folder" />
            <Button Content="Start" />
            <Button Content="Stop" />

        </StackPanel>

        <!-- CENTER: JOB LIST -->
        <ListView Grid.Column="1" ItemsSource="{x:Bind ViewModel.State.Jobs}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="client:JobViewModel">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{x:Bind FileName}" Width="200"/>
                        <TextBlock Text="{x:Bind State}" Width="150"/>
                        <TextBlock Text="{x:Bind Error}" Foreground="Red"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- RIGHT: LOGS -->
        <ListView Grid.Column="2" ItemsSource="{x:Bind ViewModel.State.Logs}">
        </ListView>

    </Grid>
</Window>
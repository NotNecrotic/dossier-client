<Window
    x:Class="Dossier.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Dossier">

    <Grid ColumnDefinitions="280,*,320">

        <!-- LEFT: SETTINGS + FOLDERS -->
        <Border Grid.Column="0" Background="#111" Padding="10">
            <StackPanel Spacing="12">

                <TextBlock Text="Settings" FontSize="18" />

                <TextBox Header="Server URL" Text="{Binding ServerUrl}" />
                <TextBox Header="API Key" Text="{Binding ApiKey}" />

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Ellipse Width="10" Height="10"
                             Fill="{Binding ConnectionColor}" />
                    <TextBlock Text="{Binding ConnectionStatus}" />
                </StackPanel>

                <Button Content="Test Connection" />

                <TextBlock Text="Folders" Margin="0,10,0,0"/>

                <ListView ItemsSource="{Binding Folders}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button Content="Add Folder" />
                <Button Content="Remove Selected" />

            </StackPanel>
        </Border>

        <!-- CENTER: FILE EXPLORER GRID -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding CurrentFolder}" FontSize="16" Margin="10"/>

            <GridView Grid.Row="1"
                      ItemsSource="{Binding Videos}"
                      IsItemClickEnabled="True">

                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="160" Height="120" Margin="6" Padding="6"
                                Background="#222" CornerRadius="8">

                            <StackPanel>
                                <TextBlock Text="{Binding FileName}"
                                           TextWrapping="Wrap"
                                           FontSize="12"/>

                                <TextBlock Text="{Binding State}"
                                           FontSize="11"
                                           Opacity="0.7"/>

                                <Rectangle Height="6"
                                           Fill="{Binding StatusColor}" />
                            </StackPanel>

                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>

            </GridView>
        </Grid>

        <!-- RIGHT: LOG PANEL -->
        <Border Grid.Column="2" Background="#0E0E0E" Padding="10">
            <StackPanel>
                <TextBlock Text="Logs" FontSize="16"/>

                <ListView ItemsSource="{Binding Logs}" />
            </StackPanel>
        </Border>

    </Grid>
</Window>